# ===================
# BASE DE DONNÉES
# ===================
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/duniya_db
SPRING_DATASOURCE_USERNAME=duniya_user
SPRING_DATASOURCE_PASSWORD=DuniyaSecure@2025

MYSQL_DATABASE=duniya_db
MYSQL_USER=duniya_user
MYSQL_PASSWORD=DuniyaSecure@2025
MYSQL_ROOT_PASSWORD=DuniyaRootSecure@2025

# ===================
# CONFIGURATION EMAIL
# ===================
EMAIL_HOST=mail.duniyaconnect.com
EMAIL_PORT=587
EMAIL_USERNAME=no-reply@duniyaconnect.com
EMAIL_PASSWORD=Passer@123
EMAIL_FROM=no-reply@duniyaconnect.com
EMAIL_SECRETARIAT=secretariat@duniyaconnect.com

# ===================
# SÉCURITÉ & JWT
# ===================
JWT_SECRET=VotreCleSecreteTresLongueEtComplexePourJWTDuniyaConnect2025SecureKey

# ===================
# CONFIGURATION CORS
# ===================
CORS_ALLOWED_ORIGINS=http://185.170.58.170:8082,http://localhost:4200,http://localhost:3000,https://duniyaconnect.com,https://www.duniyaconnect.com,https://api.duniyaconnect.com

# ===================
# UPLOADS & STOCKAGE
# ===================
UPLOAD_DIR_ACTUALITES=/app/uploads/actualites
UPLOAD_DIR_DIRECTEURS=/app/uploads/directeurs

# ===================
# DOMAINES & SSL
# ===================
DOMAIN_BACKEND=api.duniyaconnect.com
DOMAIN_PHPMYADMIN=phpmyadmin.duniyaconnect.com
DOMAIN_FRONTEND=duniyaconnect.com

# ===================
# CONFIGURATION SYSTÈME
# ===================
TZ=Africa/Abidjan
JAVA_OPTS=-Xms512m -Xmx1024m -Djava.security.egd=file:/dev/./urandom

# ===================
# TRAEFIK & REVERSE PROXY
# ===================
TRAEFIK_NETWORK=duniya-network
CERT_RESOLVER=le
TRAEFIK_ACME_EMAIL=ton.email@exemple.com

# ===================
# ENVIRONNEMENT
# ===================
ENVIRONMENT=production
SPRING_PROFILES_ACTIVE=prod
DEBUG=false
